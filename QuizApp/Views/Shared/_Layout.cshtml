<!DOCTYPE html>
<html>
<head>
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Quiz App</title>

    <style>
        body {
            margin: 0;
            font-family: Arial;
            background: #f5f5f5;
        }

        .header {
            background: #222;
            color: white;
            padding: 15px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

            .header a {
                color: white;
                text-decoration: none;
                margin-left: 10px;
                font-size: 14px;
            }

        .container {
            padding: 15px;
        }

        .card {
            background: white;
            padding: 15px;
            margin-bottom: 10px;
            border-radius: 5px;
            box-shadow: 0 0 5px rgba(0,0,0,0.1);
        }

        .btn {
            display: inline-block;
            padding: 10px;
            background: #007bff;
            color: white;
            text-decoration: none;
            border-radius: 4px;
            margin-top: 5px;
            width: 100%;
            text-align: center;
        }

            .btn:hover {
                background: #0056b3;
            }

        /* 🔥 MOBILE RESPONSIVE FIX */
        @@media (max-width: 768px) {
            .header {
                flex-direction: column;
                align-items: flex-start;
            }

                .header div {
                    margin-top: 10px;
                }
        }
    </style>
</head>

<body>

    <!-- 🔥 HEADER -->
    <div class="header">
        <div><b>Quiz App</b></div>

        <div>
            <a href="/Home/Dashboard">Home</a>
            <a href="javascript:history.back()">Back</a>
            <a href="/Account/Logout">Logout</a>
        </div>
    </div>

    <!-- 🔥 BODY -->
    <div class="container">
        @RenderBody()
    </div>

</body>
</html>